<?xml version="1.0" encoding="UTF-8"?>
<component name="VideoPage" extends="Group">
    <interface>
        <field id="navRequest" type="assocarray" alwaysNotify="true" />
        <field id="params"     type="assocarray" />
    </interface>
    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/components/VideoPage.brs" />
    <children>
        <Rectangle color="0x000000FF" width="1920" height="1080" />
        <Video id="video" translation="[0,0]" width="1920" height="1080" enableTrickPlay="false" />

        <!-- ═══ SEEK OVERLAY (outside OSD — shows on every L/R press) ═══
             Centered horizontally, sits above the OSD bottom bar.
             480×120 pill at y=620 keeps it well above subtitles and the OSD. -->
        <Group id="seekOverlay" visible="false">
            <Rectangle color="0x06061AEE" width="480" height="116" translation="[720, 622]" />
            <Rectangle color="0x4A9FFFFF" width="480" height="3"   translation="[720, 622]" />
            <!-- Direction + delta  e.g. "<< 30s"  or  ">> 1:30" -->
            <Label id="seekDeltaLabel" translation="[720, 638]" width="480" horizAlign="center"
                   font="font:LargeBoldSystemFont" color="0x4A9FFFFF" />
            <!-- Absolute position  e.g. "23:45  /  45:00" -->
            <Label id="seekPosLabel" translation="[720, 696]" width="480" horizAlign="center"
                   font="font:SmallSystemFont" color="0xCCCCCCFF" />
        </Group>

        <!-- ═══ OSD ═══ -->
        <Group id="osd" visible="false">

            <!-- TOP BAR: title + state -->
            <Rectangle color="0x000000CC" width="1920" height="72" translation="[0, 0]" />
            <Label id="osdTitle" translation="[40, 22]" width="1300"
                   font="font:SmallBoldSystemFont" color="0xFFFFFFFF" />
            <Label id="osdState" translation="[1360, 22]" width="520"
                   font="font:SmallBoldSystemFont" color="0x4A9FFFFF" horizAlign="right" />

            <!-- BOTTOM BAR (no transport buttons — seek is always L/R) -->
            <Rectangle color="0x000000CC" width="1920" height="180" translation="[0, 900]" />

            <!-- Seek bar — y=918, h=6 -->
            <Rectangle id="seekBg"   translation="[60, 918]" width="1800" height="6"  color="0x2A2A50FF" />
            <Rectangle id="seekFill" translation="[60, 918]" width="0"    height="6"  color="0x4A9FFFFF" />
            <!-- Dot centered on bar: bar center y=921, dot h=14 → top y=914, x=53 when at 0% -->
            <Rectangle id="seekDot"  translation="[53, 914]" width="14"   height="14" color="0x4A9FFFFF" />

            <!-- Time labels -->
            <Label id="osdCurrentTime" translation="[60,   940]" width="220"
                   font="font:SmallSystemFont" color="0xFFFFFFFF" />
            <Label id="osdTotalTime"   translation="[1640, 940]" width="220"
                   font="font:SmallSystemFont" color="0x666688FF" horizAlign="right" />

            <!-- Hint -->
            <Label translation="[60, 1046]"
                   text="← / → = seek 10s     OK = play/pause     * = subtitles     Back = exit"
                   font="font:SmallSystemFont" color="0x2A2A4AFF" width="1800" horizAlign="center" />
        </Group>

        <!-- ═══ SUBTITLE PANEL ═══ -->
        <Group id="subtitlePanel" visible="false">
            <Rectangle color="0x080818F2" width="500" height="286" translation="[710, 380]" />
            <Rectangle color="0x4A9FFFFF" width="500" height="4"   translation="[710, 380]" />
            <Label translation="[734, 400]" text="SUBTITLES"
                   font="font:SmallBoldSystemFont" color="0x4A9FFFFF" width="460" />
            <Rectangle id="subItem0" color="0x152840FF" width="460" height="58" translation="[730, 438]" />
            <Label     id="subLabel0" translation="[754, 457]" text="Off"
                       font="font:SmallBoldSystemFont" color="0xFFFFFFFF" width="420" />
            <Rectangle id="subItem1" color="0x0A0A20FF" width="460" height="58" translation="[730, 506]" />
            <Label     id="subLabel1" translation="[754, 525]" text="On (Captions)"
                       font="font:SmallBoldSystemFont" color="0xCCCCCCFF" width="420" />
            <Label translation="[730, 596]"
                   text="Up / Down = navigate     OK = select     Back = close"
                   font="font:SmallSystemFont" color="0x444466FF" width="460" />
        </Group>

        <!-- ═══ UP NEXT TOAST ═══ -->
        <Group id="autoplayPanel" visible="false">
            <Rectangle color="0x08081AEE" width="600" height="170" translation="[1296, 720]" />
            <Rectangle color="0x4A9FFFFF" width="4"   height="170" translation="[1296, 720]" />
            <Label translation="[1314, 734]" text="UP NEXT"
                   font="font:SmallBoldSystemFont" color="0x4A9FFFFF" width="560" />
            <Label id="autoplayTitle" translation="[1314, 762]" text=""
                   font="font:SmallBoldSystemFont" color="0xFFFFFFFF" width="560" wrap="true" numLines="2" />
            <Label id="autoplayLabel" translation="[1314, 836]" text=""
                   font="font:SmallSystemFont" color="0xAAAAAAFF" width="300" />
            <Label translation="[1314, 860]" text="OK = play now   Back = dismiss"
                   font="font:SmallSystemFont" color="0x44444499" width="560" />
            <Rectangle color="0x1C2C4AFF" width="556" height="4" translation="[1318, 880]" />
            <Rectangle id="autoplayCountdownBar" color="0x4A9FFFFF" width="556" height="4" translation="[1318, 880]" />
        </Group>
    </children>
</component>
