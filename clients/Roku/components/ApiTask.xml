<?xml version="1.0" encoding="UTF-8"?>
<component name="ApiTask" extends="Task">
    <interface>
        <field id="url"       type="string" />
        <field id="method"    type="string" value="GET" />
        <field id="token"     type="string" />
        <field id="reqBody"   type="string" />
        <field id="result"    type="assocarray" alwaysNotify="true" />
        <field id="resultArr" type="array"      alwaysNotify="true" />
        <field id="apiError"  type="string"     alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/ApiTask.brs" />
</component>
