# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
#
# SECRET_KEY is auto-generated on first run — you only need to set this
# if you want a specific value (e.g. to keep sessions alive across reinstalls).
# SECRET_KEY=

# Third-party API keys (optional — features degrade gracefully without them)
TMDB_API_KEY=
OPENSUBTITLES_API_KEY=
SUBDL_API_KEY=
